# Copy to .env and edit, then:
#   set -a; source ./.env; set +a
#
# rpi-image-gen will read IGconf_* vars passed on the CLI. This file is just a convenience.

# Target device layer (upstream rpi-image-gen)
IGconf_device_layer=rpi5-ubuntu

# Login creds (upstream rpi-user-credentials layer)
IGconf_device_user1=robot
IGconf_device_user1pass=Robot1234!

# Wi-Fi (this recipe)
IGconf_wifi_ssid=MyWiFi
IGconf_wifi_psk=MyWiFiPassword
IGconf_wifi_country=US

# ROS 2 packages (this recipe) — ros-base or desktop
IGconf_ros_variant=ros-base

# Output image name (optional)
IGconf_image_name=ubuntu22-ros2-camera
