  <!-- END AUTO-GENERATED ROOT FIX -->
  <!-- Kinematic chain for gantry + robotic arms -->
  <!-- These helper frame links group the parent-child hierarchy explicitly. -->
  <link name="x_axis_carriage" />
  <link name="y_axis_carriage" />
  <link name="z_axis_carriage" />
  <link name="arm_platform" />
  <link name="arm1_mount" />
  <link name="arm2_mount" />
  <link name="arm3_mount" />
  <link name="arm4_mount" />

  <!-- X axis: one prismatic stage that carries both parallel rails -->
  <joint name="x_axis_prismatic_joint" type="prismatic">
    <parent link="x_axis_tracks_inertial" />
    <child link="x_axis_carriage" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-1.0" upper="1.0" effort="1000" velocity="1.0" />
  </joint>
  <joint name="x_axis_left_rail_mount_joint" type="fixed">
    <parent link="x_axis_carriage" />
    <child link="v_slot_20x80x200_linear_rail" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <joint name="x_axis_right_rail_mount_joint" type="fixed">
    <parent link="x_axis_carriage" />
    <child link="v_slot_20x80x200_linear_rail_2" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <!-- Y and Z linear stages -->
  <joint name="y_axis_prismatic_joint" type="prismatic">
    <parent link="x_axis_carriage" />
    <child link="y_axis_carriage" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-1.0" upper="1.0" effort="1000" velocity="1.0" />
  </joint>
  <joint name="z_axis_base_mount_joint" type="fixed">
    <parent link="y_axis_carriage" />
    <child link="z_axis_base" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <joint name="z_axis_prismatic_joint" type="prismatic">
    <parent link="z_axis_base" />
    <child link="z_axis_carriage" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.5" upper="0.5" effort="1000" velocity="0.5" />
