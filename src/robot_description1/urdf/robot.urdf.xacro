      <p_gain>200</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>20</d_gain>
      <cmd_max>1000</cmd_max>
      <cmd_min>-1000</cmd_min>
    </plugin>
  </gazebo>
  <gazebo>
