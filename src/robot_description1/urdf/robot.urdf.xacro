  <!-- Joint from body to gantry_column -->
  <joint name="extra_root_2_to_gantry_column" type="prismatic">
    <origin xyz="0 0 0" rpy="0 -0 0"/>
    <parent link="body"/>
    <child link="gantry_column"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="10" lower="-1" upper="1"/>
  </joint>
  <gazebo>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>
  <gazebo>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>extra_root_2_to_gantry_column</joint_name>
      <topic>/sim/extra_root_2_to_gantry_column/cmd_pos</topic>
      <p_gain>200</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>20</d_gain>
      <cmd_max>1000</cmd_max>
      <cmd_min>-1000</cmd_min>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>extra_root_1_to_axis1</joint_name>
